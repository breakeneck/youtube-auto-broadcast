# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Broadcast Database (PostgreSQL)
BROADCAST_DB_NAME=broadcast
BROADCAST_DB_USER=postgres
BROADCAST_DB_PASSWORD=postgres
BROADCAST_DB_HOST=localhost
BROADCAST_DB_PORT=5432

# Shastra Database (PostgreSQL) - existing database with shlokas
SHASTRA_DB_NAME=shastra_parser
SHASTRA_DB_USER=postgres
SHASTRA_DB_PASSWORD=postgres
SHASTRA_DB_HOST=localhost
SHASTRA_DB_PORT=5432

# YouTube API
YOUTUBE_PRIVACY=public
YOUTUBE_STREAM_ID=your-stream-id-here
YOUTUBE_AUTH_FILE=/path/to/client_secret.json

# OBS Remote
OBS_HOST=
OBS_PORT=
OBS_USERNAME=
OBS_PASSWORD=

# Telegram Bot
TG_API_TOKEN=your-telegram-bot-token
TG_CHAT_ID=
TG_SUBCHANNEL_ID=

# Schedule Settings
MORNING_SB_START_TIME=07:00
MORNING_SB_END_TIME=08:30
DEFAULT_BROADCAST_DURATION_MINUTES=120

# Session Settings
SESSION_COOKIE_AGE=2592000  # 30 days in seconds
